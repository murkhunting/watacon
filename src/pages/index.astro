---
import Layout from '../layouts/Layout.astro';
import SplineScene from '../components/SplineScene';
---

<Layout title="Inicio">
  <section slot="hero" class="fixed inset-0 z-[2]">
    <SplineScene client:only="react" scene="https://prod.spline.design/nRf75y4OY1da7lTT/scene.splinecode" />
  </section>

  <section class="flex items-center justify-center min-h-[calc(100vh-5rem)]">
    <div class="text-center text-white">
      <h1 class="text-5xl md:text-7xl font-bold mb-6">Watacon</h1>
      <p class="text-xl md:text-2xl text-white/80">Soluciones web para tu negocio</p>
    </div>
  </section>
</Layout>
