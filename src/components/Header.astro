---
const navItems = [
  { label: 'Inicio', href: '/' },
  { label: 'Desarrollo Web', href: '/desarrollo-web' },
  { label: 'Tiendas Online', href: '/tiendas-online' },
  { label: 'SEO y Marketing', href: '/seo-marketing' },
  { label: 'Mantenimiento Web', href: '/mantenimiento-web' },
  { label: 'Hosting y Dominios', href: '/hosting-dominios' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-20 bg-black/60 backdrop-blur-md">
  <nav class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
    <a href="/" class="text-white text-2xl font-bold tracking-tight">
      Watacon
    </a>
    <ul class="hidden lg:flex items-center gap-6">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="text-white/80 hover:text-white transition-colors text-sm font-medium"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
