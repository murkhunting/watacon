---
const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Desarrollo Web", href: "/desarrollo-web" },
  { label: "Tiendas Online", href: "/tiendas-online" },
  { label: "SEO y Marketing", href: "/seo-marketing" },
  { label: "Mantenimiento Web", href: "/mantenimiento-web" },
  { label: "Hosting y Dominios", href: "/hosting-dominios" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Blog", href: "/blog" },
  { label: "Contacto", href: "/contacto" },
];
---

<a
  href="/"
  id="header-logo"
  class="fixed top-3 left-3 z-[10000] flex items-center gap-3 bg-white/10 backdrop-blur-xl rounded-full p-2"
>
  <img src="/img/watacon-logo.svg" alt="Watacon" class="w-20 h-20 transition-transform duration-500 hover:rotate-[240deg]" />
</a>

<button
  id="menu-toggle"
  class="fixed top-3 right-3 z-[10000] flex items-center gap-4 bg-primary rounded-full py-2 pr-2 pl-6 cursor-pointer"
>
  <span class="text-dark text-lg font-semibold">Menu</span>
  <div class="bg-dark rounded-full p-2">
    <div class="relative w-6 h-6">
      <span
        id="bar1"
        class="absolute left-0 top-1 block h-[3px] w-full bg-primary rounded transition-all duration-300"
      ></span>
      <span
        id="bar2"
        class="absolute left-0 top-1/2 -translate-y-1/2 block h-[3px] w-full bg-primary rounded transition-all duration-300"
      ></span>
      <span
        id="bar3"
        class="absolute left-0 bottom-1 block h-[3px] w-full bg-primary rounded transition-all duration-300"
      ></span>
    </div>
  </div>
</button>

<div
  id="menu-overlay"
  class="fixed left-0 right-0 top-0 pointer-events-none transition-transform duration-500 ease-in-out"
  style="z-index: 9999; transform: translateY(-100%);"
>
  <div class="bg-primary min-h-screen">
    <nav class="flex items-center justify-center min-h-screen">
      <ul class="flex flex-col items-center gap-8">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="nav-link text-dark/80 hover:text-dark text-3xl font-medium transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const menuOverlay = document.getElementById("menu-overlay");
  const bar1 = document.getElementById("bar1");
  const bar2 = document.getElementById("bar2");
  const bar3 = document.getElementById("bar3");
  const navLinks = document.querySelectorAll(".nav-link");

  let isOpen = false;

  document.body.appendChild(menuOverlay);

  function openMenu() {
    isOpen = true;
    menuOverlay.classList.remove("pointer-events-none");
    menuOverlay.classList.add("pointer-events-auto");
    menuOverlay.style.transform = "translateY(0)";
    bar1.className =
      "absolute left-0 block h-[3px] w-full bg-primary rounded transition-all duration-300 top-1/2 -translate-y-1/2 rotate-45";
    bar2.className =
      "absolute left-0 top-1/2 -translate-y-1/2 block h-[3px] w-full bg-primary rounded transition-all duration-300 opacity-0";
    bar3.className =
      "absolute left-0 block h-[3px] w-full bg-primary rounded transition-all duration-300 top-1/2 -translate-y-1/2 -rotate-45";
  }

  function closeMenu() {
    isOpen = false;
    menuOverlay.classList.remove("pointer-events-auto");
    menuOverlay.classList.add("pointer-events-none");
    menuOverlay.style.transform = "translateY(-100%)";
    bar1.className =
      "absolute left-0 top-1 block h-[3px] w-full bg-primary rounded transition-all duration-300";
    bar2.className =
      "absolute left-0 top-1/2 -translate-y-1/2 block h-[3px] w-full bg-primary rounded transition-all duration-300";
    bar3.className =
      "absolute left-0 bottom-1 block h-[3px] w-full bg-primary rounded transition-all duration-300";
  }

  function toggleMenu() {
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  }

  menuToggle.addEventListener("click", toggleMenu);

  navLinks.forEach(function (link) {
    link.addEventListener("click", closeMenu);
  });
</script>
