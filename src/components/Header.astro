---
const navRight = [
  { label: "Inicio", href: "/" },
  { label: "Nosotros", href: "/nosotros" },
  { label: "Blog", href: "/blog" },
  { label: "Contacto", href: "/contacto" },
];
---

<!-- LOGO -->
<a
  href="/"
  id="header-logo"
  class="fixed top-4 left-4 z-[10000] flex items-center gap-3"
>
  <img
    src="/img/watacon-logo.png"
    alt="Watacon"
    class="w-22 h-22 drop-shadow-lg transition-transform duration-500 hover:rotate-[480deg]"
  />
</a>
<!-- OPEN MENU BUTTON -->
<button
  id="menu-toggle"
  class="fixed top-4 left-1/2 -translate-x-1/2 z-[10000] flex items-center justify-between w-[130px] bg-light rounded-full py-1 pr-1 pl-4 cursor-pointer shadow-lg hover:-translate-y-[4px] transition-all duration-300"
>
  <span id="menu-text" class="text-dark text-lg font-bold">Menú</span>
  <div class="bg-dark rounded-full p-2">
    <div class="relative w-6 h-6">
      <span
        id="bar1"
        class="absolute left-0 top-1 block h-[2px] w-full bg-primary rounded transition-all duration-300"
      ></span>
      <span
        id="bar2"
        class="absolute left-0 top-1/2 -translate-y-1/2 block h-[2px] w-full bg-primary rounded transition-all duration-300"
      ></span>
      <span
        id="bar3"
        class="absolute left-0 bottom-1 block h-[2px] w-full bg-primary rounded transition-all duration-300"
      ></span>
    </div>
  </div>
</button>
<button
  id="menu-toggle"
  class="fixed top-4 right-4 z-[10000] h-12 flex items-center justify-between w-[150px] bg-light rounded-full py-1 px-4 cursor-pointer shadow-lg hover:-translate-y-[4px] transition-all duration-300"
>
  <span class="text-dark text-lg font-bold">Hablemos</span>
  <i class="ph-bold ph-arrow-up-right text-[25px] text-dark"></i>
</button>

<!-- MENU -->
<div
  id="menu-overlay"
  class="overflow-hidden fixed inset-0 pointer-events-none"
  style="z-index: 9999;"
>
  <div class="bg-dark/70 backdrop-blur-[35px] rounded-[30px] min-h-screen">
    <div class="h-full flex flex-row p-4 gap-6">
      <div
        class="w-[75%] rounded-[30px] h-[95vh] p-8 flex flex-col items-center justify-center overflow-hidden"
      >
        <nav>
          <a
            href="/web"
            class="w-full flex flex-row items-center justify-center p-4 gap-4 group relative"
          >
            <h2
              class="nav-link text-light text-center py-0 px-6 rounded-full hover:text-dark hover:bg-primary text-[4vw] font-bold relative z-10 transition-colors duration-300"
            >
              Webs Corporativas
            </h2>
            <img
              class="w-[30vw] h-[40vh] rounded-[30px] object-cover absolute left-[-25vw] -translate-x-full group-hover:translate-x-[13vw] transition-transform duration-300 z-0"
              src="/img/web.png"
              alt="Tiendas Online"
            />
          </a>
          <a
            href="/ecommerce"
            class="flex flex-row items-center justify-center p-4 gap-4 group relative w-full"
          >
            <h2
              class="nav-link text-light text-center py-0 px-6 rounded-full hover:text-dark hover:bg-primary text-[4vw] font-bold relative z-10 transition-colors duration-300"
            >
              Tiendas Online
            </h2>
            <img
              class="w-[30vw] h-[40vh] rounded-[30px] object-cover absolute left-[-25vw] -translate-x-full group-hover:translate-x-[13vw] transition-transform duration-300 z-0"
              src="/img/web.png"
              alt="Tiendas Online"
            />
          </a>
          <a
            href="/seo"
            class="flex flex-row items-center justify-center p-4 gap-4 group relative w-full"
          >
            <h2
              class="nav-link text-light text-center py-0 px-6 rounded-full hover:text-dark hover:bg-primary text-[4vw] font-bold relative z-10 transition-colors duration-300"
            >
              SEO y Optimización
            </h2>
            <img
              class="w-[30vw] h-[40vh] rounded-[30px] object-cover absolute left-[-25vw] -translate-x-full group-hover:translate-x-[13vw] transition-transform duration-300 z-0"
              src="/img/web.png"
              alt="Tiendas Online"
            />
          </a>
          <a
            href="/mantenimiento"
            class="flex flex-row items-center justify-center p-4 gap-4 group relative w-full"
          >
            <h2
              class="nav-link text-light text-center py-0 px-6 rounded-full hover:text-dark hover:bg-primary text-[4vw] font-bold relative z-10 transition-colors duration-300"
            >
              Mantenimiento
            </h2>
            <img
              class="w-[30vw] h-[40vh] rounded-[30px] object-cover absolute left-[-25vw] -translate-x-full group-hover:translate-x-[13vw] transition-transform duration-300 z-0"
              src="/img/web.png"
              alt="Tiendas Online"
            />
          </a>
        </nav>
      </div>
      <div
        class="w-[25%] overflow-hidden rounded-[30px] bg-light mt-15 pt-10 px-10 pb-8 flex flex-col justify-between"
      >
        <nav class="z-10">
          <ul class="flex flex-col items-start gap-6">
            {
              navRight.map((item) => (
                <li>
                  <a href={item.href}>
                    <h3 class="nav-link text-right text-dark rounded-full py-1 px-4 hover:text-primary hover:bg-dark text-4xl font-bold hover:translate-x-[6px] transition-all duration-300">
                      {item.label}
                    </h3>
                  </a>
                </li>
              ))
            }
          </ul>
          <div
            class="mt-10 ml-2 flex flex-row items-center justify-star z-10 gap-4"
          >
            <a
              href="https://wa.me/XXXXXXXXX"
              target="_blank"
              class="p-2 rounded-full bg-dark text-primary flex items-center justify-center transition-all duration-300 hover:-translate-y-[3px]"
            >
              <i class="ph ph-whatsapp-logo text-[30px]"></i>
            </a>
            <a
              href="mailto:info@watacon.com"
              class="p-2 rounded-full bg-dark text-primary flex items-center justify-center transition-all duration-300 hover:-translate-y-[4px]"
            >
              <i class="ph ph-envelope text-[30px]"></i>
            </a>
            <a
              href="tel:+XXXXXXXXX"
              class="p-2 rounded-full bg-dark text-primary flex items-center justify-center transition-all duration-300 hover:-translate-y-[4px]"
            >
              <i class="ph ph-phone text-[30px]"></i>
            </a>
          </div>
        </nav>
        <img
          src="/img/watacon-logo-dark.svg"
          alt="Watacon"
          class="absolute bottom-[-20%] w-auto h-[550px] max-w-none opacity-10 z-1"
        />
        <div class="flex flex-row items-center justify-end gap-4 z-2">
          <h2 class="text-dark text-[1.4vw] font-bold">
            &copy; {new Date().getFullYear()} | Watacon
          </h2>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { gsap } from "gsap";

    const menuToggle = document.getElementById("menu-toggle");
    const menuText = document.getElementById("menu-text");
    const menuOverlay = document.getElementById("menu-overlay");
    const bar1 = document.getElementById("bar1");
    const bar2 = document.getElementById("bar2");
    const bar3 = document.getElementById("bar3");
    const navLinks = document.querySelectorAll(".nav-link");

    const menuInner = document.querySelector("#menu-overlay .flex-row");
    const leftDiv = menuInner.children[0];
    const rightDiv = menuInner.children[1];
    const h2Elements = leftDiv.querySelectorAll("h2");

    let isOpen = false;

    document.body.appendChild(menuOverlay);

    gsap.set(menuOverlay, {
      scale: 0,
      transformOrigin: "top right",
    });
    gsap.set(h2Elements, { autoAlpha: 0, y: -30 });
    gsap.set(rightDiv, { autoAlpha: 0, x: "100%" });

    let tl = gsap.timeline({ paused: true });

    tl.to(menuOverlay, {
      scale: 1,
      duration: 0.6,
      ease: "power2.inOut",
    })
      .to(h2Elements, {
        autoAlpha: 1,
        y: 0,
        stagger: 0.1,
        duration: 0.4,
        ease: "power2.out",
      })
      .to(
        rightDiv,
        {
          autoAlpha: 1,
          x: "0%",
          duration: 0.4,
          ease: "power2.out",
        },
        "-=0.1",
      );

    tl.eventCallback("onReverseComplete", () => {
      menuOverlay.classList.add("pointer-events-none");
      menuOverlay.classList.remove("pointer-events-auto");
    });

    function openMenu() {
      if (isOpen) return;
      isOpen = true;
      menuOverlay.classList.remove("pointer-events-none");
      menuOverlay.classList.add("pointer-events-auto");
      tl.play();
      gsap.to(menuText, {
        autoAlpha: 0,
        duration: 0.08,
        onComplete: () => {
          menuText.textContent = "Cerrar";
          gsap.to(menuText, { autoAlpha: 1, duration: 0.08 });
        },
      });
      bar1.className =
        "absolute left-0 block h-[2px] w-full bg-primary rounded transition-all duration-300 top-1/2 -translate-y-1/2 rotate-45";
      bar2.className =
        "absolute left-0 top-1/2 -translate-y-1/2 block h-[2px] w-full bg-primary rounded transition-all duration-300 opacity-0";
      bar3.className =
        "absolute left-0 block h-[2px] w-full bg-primary rounded transition-all duration-300 top-1/2 -translate-y-1/2 -rotate-45";
    }

    function closeMenu() {
      if (!isOpen) return;
      isOpen = false;
      tl.reverse();
      gsap.to(menuText, {
        autoAlpha: 0,
        duration: 0.08,
        onComplete: () => {
          menuText.textContent = "Menú";
          gsap.to(menuText, { autoAlpha: 1, duration: 0.08 });
        },
      });
      bar1.className =
        "absolute left-0 top-1 block h-[2px] w-full bg-primary rounded transition-all duration-300";
      bar2.className =
        "absolute left-0 top-1/2 -translate-y-1/2 block h-[2px] w-full bg-primary rounded transition-all duration-300";
      bar3.className =
        "absolute left-0 bottom-1 block h-[2px] w-full bg-primary rounded transition-all duration-300";
    }

    function toggleMenu() {
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    menuToggle.addEventListener("click", toggleMenu);

    navLinks.forEach(function (link) {
      link.addEventListener("click", closeMenu);
    });
  </script>
</div>
