---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Watacon</title>
  </head>
  <body class="w-screen h-screen overflow-hidden">
    <video
      class="fixed inset-0 w-full h-full object-cover z-0"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/videos/watacon.mp4" type="video/mp4" />
    </video>

    <div class="fixed inset-0 z-[1] bg-[#192339]/95"></div>

    <Header />

    <div class="relative z-10 w-full h-full overflow-y-auto">
      <div class="min-h-screen pt-20 flex flex-col">
        <main class="flex-1">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
